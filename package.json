{
  "name": "@ai-zen/agents-cli",
  "version": "0.9.8",
  "description": "AI-ZEN Agents CLI - interactive conversation terminal with file tools, MCP support, and draft recovery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "aiz": "dist/index.js"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "prepublishOnly": "node scripts/check-publish-tool.mjs && npm run build",
    "start": "npm run build && node ./dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "chat",
    "mcp",
    "model-context-protocol",
    "autonomous-agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-zen/agents-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.21",
    "inquirer": "^9.2.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
