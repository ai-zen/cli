{
  "name": "@ai-zen/cli",
  "version": "1.0.0",
  "description": "AI-ZEN CLI - interactive conversation terminal with file tools and draft recovery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "aiz": "dist/index.js",
    "zen": "dist/index.js"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "start": "npm run build && node ./dist/index.js",
    "test": "vitest run --exclude src/__tests__/e2e.test.ts",
    "test:e2e": "vitest run src/__tests__/e2e.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "chat",
    "autonomous-agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-zen/agents-core": "^2.6.1",
    "@ai-zen/agents-sdk": "^0.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.21",
    "inquirer": "^9.2.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
